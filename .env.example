# ══════════════════════════════════════════════════════════════
#  DSTAC Platform — Variables de entorno
#  Copiar este archivo a:
#    apps/api/.env          (backend)
#    apps/web/.env.local    (frontend)
#  NUNCA subir los archivos .env reales al repositorio.
# ══════════════════════════════════════════════════════════════

# ── Base de datos ──────────────────────────────────────────────
# En producción usar 127.0.0.1 en vez de localhost (fuerza TCP)
DB_HOST=127.0.0.1
DB_USER=dstac_user
DB_PASSWORD=CAMBIAR_POR_CONTRASEÑA_SEGURA
DB_CENTRAL=db_dstac_core

# ── JWT ────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CADENA_ALEATORIA_DE_64_CARACTERES_MINIMO_AQUI
JWT_EXPIRES_IN=8h

# ── Email / SMTP ───────────────────────────────────────────────
SMTP_HOST=mail.tudominio.cl
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@tudominio.cl
SMTP_PASS=CAMBIAR_POR_PASSWORD_DEL_CORREO

# ── App ────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001

# URL pública del API (usada por el navegador)
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL interna del API (usada por Next.js en el servidor para rewrites)
INTERNAL_API_URL=http://localhost:3001

# Origen permitido para CORS (URL del frontend)
FRONTEND_URL=http://localhost:3000

# ── Seguridad ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MFA_EXPIRES_MINUTES=5

# ── Mercado Público (módulo Oportunidades) ──────────────────────
# Ticket gratuito: mercadopublico.cl > Empresas > Servicios > API
# Sin esto, la sincronización de licitaciones falla en silencio (queda logueado).
MERCADOPUBLICO_TICKET=

# ══════════════════════════════════════════════════════════════
#  VALORES PARA PRODUCCIÓN (reemplazar los de arriba)
# ──────────────────────────────────────────────────────────────
#  DB_HOST=127.0.0.1
#  NODE_ENV=production
#  NEXT_PUBLIC_API_URL=https://tudominio.cl/api
#  INTERNAL_API_URL=http://localhost:3001
#  FRONTEND_URL=https://tudominio.cl
# ══════════════════════════════════════════════════════════════
